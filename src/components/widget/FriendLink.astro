---
interface Props {
	friends: Array<{
		name: string;
		url: string;
		avatar: string;
		description: string;
	}>;
}

const { friends } = Astro.props;
---

<div class="friend-links-container">
  {friends.map((friend) => (
    <div class="friend-link-card">
      <div class="friend-avatar">
        <img src={friend.avatar} alt={friend.name} />
      </div>
      <div class="friend-info">
        <h3 class="friend-name">{friend.name}</h3>
        <p class="friend-description">{friend.description}</p>
      </div>
      <a
        href={friend.url}
        target="_blank"
        rel="noopener noreferrer"
        class="friend-arrow"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="icon icon-tabler icon-tabler-chevron-right" width="20" height="20" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
          <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
          <path d="M9 6l6 6l-6 6"/>
        </svg>
      </a>
    </div>
  ))}
</div>

<style scoped>
.friend-links-container {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
  gap: 1rem;
  margin: 1.5rem 0;
}

.friend-link-card {
  padding: 1px;
  display: flex;
  align-items: center;
  background: var(--card-bg);
  border-radius: var(--radius-large);
  box-shadow: var(--shadow-sm);
  transition: all 0.2s ease;
  text-decoration: none;
  color: var(--text-primary);
  border: 1px solid var(--btn-regular-bg);
  position: relative;
  min-height: 100px;
  gap: 1rem;
}

.friend-avatar {
  width: 100px;
  height: 100px;
  overflow: hidden;
  flex-shrink: 0;
  background-color: var(--primary);
}

.friend-avatar img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.friend-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.friend-name {
  margin: 0 0 0.25rem 0;
  font-size: 1rem;
  font-weight: 600;
  color: var(--primary);
  line-height: 1.2;
}

.friend-description {
  margin: 0;
  font-size: 0.8rem;
  color: var(--text-secondary);
  line-height: 1.4;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.friend-arrow {
  background: var(--btn-regular-bg);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--primary);
  height: 100%;
  min-width: 60px;
  text-decoration: none;
  transition: all 0.2s ease;
  position: relative;
  border-top-right-radius: var(--radius-large);
  border-bottom-right-radius: var(--radius-large);
  border-top-left-radius: 0;
  border-bottom-left-radius: 0;
}

.friend-arrow:hover {
  background: var(--primary);
  color: white;
}

.friend-arrow:hover svg {
  animation: arrow-move 0.5s ease forwards;
}

.friend-arrow svg {
  width: 24px;
  height: 24px;
  transition: all 0.2s ease;
}

@keyframes arrow-move {
  0% {
    transform: translateX(0);
  }
  100% {
    transform: translateX(5px);
  }
}

@media (max-width: 768px) {
  .friend-links-container {
    grid-template-columns: 1fr;
  }
  
  .friend-avatar {
    width: 45px;
    height: 45px;
  }
  
  .friend-name {
    font-size: 0.95rem;
  }
  
  .friend-description {
    font-size: 0.75rem;
  }
  
  .friend-arrow {
    padding-left: 0.75rem;
    padding-right: 0.75rem;
    min-width: 50px;
  }
  
  .friend-arrow svg {
    width: 20px;
    height: 20px;
  }
}
</style>