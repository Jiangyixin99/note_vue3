---
import MainGridLayout from "@layouts/MainGridLayout.astro";
import FriendLink from "@components/widget/FriendLink.astro";
import Markdown from "@components/misc/Markdown.astro";
import I18nKey from "../i18n/i18nKey";
import { i18n } from "../i18n/translation";
import { getEntry, render } from "astro:content";

// 友链数据
const friends = [
  {
    name: "Humans",
    url: "https://humans-y.github.io/Humans-Y/",
    avatar: "../src/content/friendLink/humans.jpg",
    description: "这是一个示例博客，分享技术文章和生活感悟",
  }
];

// 从content/friendLink/index.md读取友链说明内容
const friendLinkEntry = await getEntry("friendLink", "index");

if (!friendLinkEntry) {
  throw new Error("Friend link description not found");
}

const { Content } = await render(friendLinkEntry);
---

<MainGridLayout title={i18n(I18nKey.friendLink)} description={i18n(I18nKey.friendLink)}>
  <div class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative min-h-32">
    <div class="card-base z-10 px-9 py-6 relative w-full">
      <h1 class="text-2xl font-bold mb-6 text-[var(--primary)]">{i18n(I18nKey.friendLink)}</h1>
      
      <!-- 友链组件部分 -->
      <section class="friend-links-section mb-8">
        <h2 class="text-xl font-semibold mb-4 text-[var(--text-primary)]">我的朋友们</h2>
        <FriendLink friends={friends} />
      </section>
      
      <!-- Markdown说明部分 -->
      <section class="friend-link-description">
        <Markdown class="mt-2">
          <Content />
        </Markdown>
      </section>
    </div>
  </div>
</MainGridLayout>