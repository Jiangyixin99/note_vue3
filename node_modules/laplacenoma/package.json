{
  "name": "laplacenoma",
  "type": "module",
  "version": "0.0.3",
  "description": "Reactivity analyzer for signal-based library",
  "author": "KazariEX",
  "license": "MIT",
  "repository": "KazariEX/laplacenoma",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./rules/vue": {
      "import": "./dist/rules/vue.js",
      "require": "./dist/rules/vue.cjs"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.cts",
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@types/node": "^24.4.0",
    "@zinkawaii/eslint-config": "^0.4.1",
    "@zinkawaii/tsconfig": "^0.0.2",
    "bumpp": "^10.2.3",
    "eslint": "^9.35.0",
    "tsdown": "^0.15.1",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown -w",
    "release": "bumpp --no-push -c \"release: v%s\"",
    "test": "vitest"
  }
}